{
  "category": "ai",
  "name": "AI & NLP",
  "description": "Translation, sentiment analysis, QR codes, and AI-related utilities",
  "prefix": "/ai",
  "apis": [
    {
      "id": "twinword",
      "name": "Twinword Sentiment Analysis",
      "base_url": "https://twinword-sentiment-analysis.p.rapidapi.com",
      "auth_required": false,
      "rate_limited": true,
      "endpoints": [
        {
          "path": "/ai/text/sentiment",
          "method": "GET",
          "summary": "Analyze text sentiment",
          "direct_url": "https://twinword-sentiment-analysis.p.rapidapi.com/analyze/",
          "parameters": [
            {"name": "text", "type": "query", "required": true, "description": "Text to analyze"}
          ],
          "sample_request": "https://twinword-sentiment-analysis.p.rapidapi.com/analyze/?text=I love this product!",
          "sample_response": {
            "type": "positive",
            "score": 0.85,
            "ratio": 0.9,
            "keywords": [
              {
                "word": "love",
                "score": 0.9
              },
              {
                "word": "product",
                "score": 0.1
              }
            ]
          }
        }
      ]
    },
    {
      "id": "mymemory",
      "name": "MyMemory Translation",
      "base_url": "https://api.mymemory.translated.net",
      "auth_required": false,
      "rate_limited": true,
      "endpoints": [
        {
          "path": "/ai/translate",
          "method": "GET",
          "summary": "Translate text",
          "direct_url": "https://api.mymemory.translated.net/get",
          "parameters": [
            {"name": "text", "type": "query", "required": true, "description": "Text to translate"},
            {"name": "target_lang", "type": "query", "default": "es", "description": "Target language code"}
          ],
          "sample_request": "https://api.mymemory.translated.net/get?q=Hello World!&langpair=en|es",
          "sample_response": {
            "responseStatus": 200,
            "responseData": {
              "translatedText": "¡Hola Mundo!",
              "match": 1
            },
            "matches": [
              {
                "id": "123456789",
                "segment": "Hello World!",
                "translation": "¡Hola Mundo!",
                "source": "en",
                "target": "es",
                "quality": 74,
                "reference": "Machine Translation",
                "usage-count": 123,
                "created-by": "MT!"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "qrserver",
      "name": "QR Server",
      "base_url": "https://api.qrserver.com/v1",
      "auth_required": false,
      "rate_limited": false,
      "endpoints": [
        {
          "path": "/ai/qrcode",
          "method": "GET",
          "summary": "Generate QR code",
          "direct_url": "https://api.qrserver.com/v1/create-qr-code/",
          "parameters": [
            {"name": "text", "type": "query", "required": true, "description": "Text to encode in QR code"}
          ],
          "sample_request": "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=https://example.com",
          "sample_response": {
            "message": "QR code generation",
            "real_url": "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=https://example.com",
            "how_to_use": "Open the URL in browser or download image"
          }
        }
      ]
    },
