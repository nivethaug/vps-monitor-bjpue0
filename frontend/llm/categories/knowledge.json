{
  "category": "knowledge",
  "name": "Knowledge & Education",
  "description": "Dictionary, books, Wikipedia, and educational resources",
  "prefix": "/knowledge",
  "apis": [
    {
      "id": "dictionaryapi",
      "name": "Free Dictionary API",
      "base_url": "https://api.dictionaryapi.dev/api/v2/entries/en",
      "auth_required": false,
      "rate_limited": false,
      "endpoints": [
        {
          "path": "/knowledge/dictionary/{word}",
          "method": "GET",
          "summary": "Get word definition",
          "direct_url": "https://api.dictionaryapi.dev/api/v2/entries/en/{word}",
          "parameters": [
            {"name": "word", "type": "path", "required": true, "description": "Word to look up"}
          ],
          "sample_request": "https://api.dictionaryapi.dev/api/v2/entries/en/hello",
          "sample_response": [
            {
              "word": "hello",
              "phonetic": "həˈləʊ",
              "phonetics": [
                {
                  "text": "həˈləʊ",
                  "audio": "//ssl.gstatic.com/dictionary/static/sounds/20200429/hello--_gb_1.mp3"
                }
              ],
              "origin": "early 19th century: variant of earlier hollo ; related to holla.",
              "meanings": [
                {
                  "partOfSpeech": "exclamation",
                  "definitions": [
                    {
                      "definition": "Used as a greeting or to begin a telephone conversation.",
                      "example": "hello there, Katie!",
                      "synonyms": [],
                      "antonyms": []
                    }
                  ]
                },
                {
                  "partOfSpeech": "noun",
                  "definitions": [
                    {
                      "definition": "An utterance of 'hello'; a greeting.",
                      "example": "she was getting polite hellos from people",
                      "synonyms": [],
                      "antonyms": []
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "openlibrary",
      "name": "Open Library",
      "base_url": "https://openlibrary.org",
      "auth_required": false,
      "rate_limited": false,
      "endpoints": [
        {
          "path": "/knowledge/books/search",
          "method": "GET",
          "summary": "Search books by title, author, or subject",
          "direct_url": "https://openlibrary.org/search.json",
          "parameters": [
            {"name": "q", "type": "query", "required": false, "description": "Search query (title, author, or subject)"},
            {"name": "limit", "type": "query", "default": 10, "description": "Number of results to return"}
          ],
          "sample_request": "https://openlibrary.org/search.json?q=python&limit=10",
          "sample_response": {
            "numFound": 10000,
            "start": 0,
            "numFoundExact": true,
            "docs": [
              {
                "key": "/works/OL12345678W",
                "type": "work",
                "title": "Python Programming",
                "author_name": ["John Doe"],
                "first_publish_year": 2000,
                "cover_i": 1234567,
                "language": ["eng"],
                "edition_count": 5
              }
            ]
          }
        },
        {
          "path": "/knowledge/books/{work_key}",
          "method": "GET",
          "summary": "Get book details by work key",
          "direct_url": "https://openlibrary.org/{work_key}.json",
          "parameters": [
            {"name": "work_key", "type": "path", "required": true, "description": "Open Library work key (e.g., OL12345678W)"}
          ],
          "sample_request": "https://openlibrary.org/works/OL12345678W.json",
          "sample_response": {
            "key": "/works/OL12345678W",
            "type": {"key": "/type/work"},
            "title": "Python Programming",
            "description": "A comprehensive guide to Python programming",
            "covers": [1234567],
            "subjects": ["Python (Computer program language)"],
            "authors": [
              {
                "type": {"key": "/type/author_role"},
                "author": {
                  "key": "/authors/OL1234567A",
                  "name": "John Doe"
                }
              }
            ],
            "created": {
              "type": "/type/datetime",
              "value": "2020-01-01T00:00:00.000000+00:00"
            }
          }
        }
      ]
    },
    {
      "id": "wikipedia",
      "name": "Wikipedia",
      "base_url": "https://en.wikipedia.org",
      "auth_required": false,
      "rate_limited": false,
      "endpoints": [
        {
          "path": "/knowledge/wikipedia/search",
          "method": "GET",
          "summary": "Search Wikipedia articles",
          "direct_url": "https://en.wikipedia.org/w/api.php?action=opensearch&format=json",
          "parameters": [
            {"name": "search", "type": "query", "required": true, "description": "Search query"},
            {"name": "limit", "type": "query", "default": 10, "description": "Number of results (1-50)"}
          ],
          "sample_request": "https://en.wikipedia.org/w/api.php?action=opensearch&search=python+programming&limit=10&format=json",
          "sample_response": [
            "python programming",
            [
              "Python (programming language)",
              "Python Software Foundation",
              "Python for S60"
            ],
            [
              "Python is a high-level, general-purpose programming language.",
              "The Python Software Foundation is the organization behind Python.",
              "Python for S60 was a port of Python to the S60 platform."
            ],
            [
              "https://en.wikipedia.org/wiki/Python_(programming_language)",
              "https://en.wikipedia.org/wiki/Python_Software_Foundation",
              "https://en.wikipedia.org/wiki/Python_for_S60"
            ]
          ]
        },
        {
          "path": "/knowledge/wikipedia/article/{title}",
          "method": "GET",
          "summary": "Get Wikipedia article summary",
          "direct_url": "https://en.wikipedia.org/api/rest_v1/page/summary/{title}",
          "parameters": [
            {"name": "title", "type": "path", "required": true, "description": "Article title"}
          ],
          "sample_request": "https://en.wikipedia.org/api/rest_v1/page/summary/Python_(programming_language)",
          "sample_response": {
            "type": "standard",
            "title": "Python (programming language)",
            "displaytitle": "Python (programming language)",
            "namespace": {
              "id": 0,
              "text": ""
            },
            "wikibase_item": "Q28865",
            "titles": {
              "canonical": "Python_(programming_language)",
              "normalized": "Python (programming language)",
              "display": "Python (programming language)"
            },
            "pageid": 23862,
            "thumbnail": {
              "source": "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Python-logo-notext.svg/200px-Python-logo-notext.svg.png",
              "width": 200,
              "height": 200
            },
            "originalimage": {
              "source": "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Python-logo-notext.svg/200px-Python-logo-notext.svg.png",
              "width": 200,
              "height": 200
            },
            "lang": "en",
            "dir": "ltr",
            "revision": "1234567890",
            "tid": "abc123",
            "timestamp": "2025-03-31T00:00:00Z",
            "description": "High-level programming language",
