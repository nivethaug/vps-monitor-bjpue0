            "extract": "Python is a high-level, general-purpose programming language. Its design philosophy emphasizes code readability with the use of significant indentation.",
            "extract_html": "<p><b>Python</b> is a high-level, general-purpose programming language. Its design philosophy emphasizes code readability with the use of significant indentation.</p>"
          }
        }
      ]
    }
  ],
  "use_cases": [
    "Look up word definitions and pronunciations",
    "Search for books by title, author, or ISBN",
    "Get detailed book information",
    "Search Wikipedia articles",
    "Get article summaries",
    "Educational research and reference"
  ]
}
