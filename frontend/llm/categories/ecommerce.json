              "rating": {
                "rate": 3.9,
                "count": 120
              }
            }
          ]
        },
        {
          "path": "/ecommerce/products/{product_id}",
          "method": "GET",
          "summary": "Get product by ID",
          "direct_url": "https://fakestoreapi.com/products/{id}",
