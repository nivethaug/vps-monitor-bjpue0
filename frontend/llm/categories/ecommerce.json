      "id": "fakestore",
      "name": "Fake Store API",
      "base_url": "https://fakestoreapi.com",
      "auth_required": false,
      "rate_limited": false,
      "status": "DOWN",
      "status_notes": "API is currently unreachable (523 error as of 2026-04-01). Use DummyJSON or Platzi API as alternatives.",
      "endpoints": [
        {
          "path": "/ecommerce/products",
          "method": "GET",
          "summary": "Get all products",
          "direct_url": "https://fakestoreapi.com/products",
